# Multiplayer server
SERVER_PORT=7070
DATABASE_URL=jdbc:postgresql://localhost:5432/jjktbf
DATABASE_USERNAME=jjktbf
DATABASE_PASSWORD=replace-with-a-database-password
POSTGRES_DB=jjktbf
POSTGRES_PORT=5432
AUTH_TOKEN_SECRET=replace-with-at-least-32-random-bytes
CHALLENGE_EXPIRY_MINUTES=15
DISCONNECT_TIMEOUT_SECONDS=30
MAX_OPEN_CHALLENGES=3

# Desktop client
GAME_SERVER_HTTP_URL=http://localhost:7070
GAME_SERVER_WS_URL=ws://localhost:7070/ws/matches

# Optional per-process desktop profile. Set a different value for each local client.
# JJKTBF_DATA_ROOT=/absolute/path/to/client-profile
